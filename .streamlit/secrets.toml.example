# TEMPLATE — copy to `.streamlit/secrets.toml` (gitignored) for local runs,
# or paste the contents into Streamlit Cloud → App → Settings → Secrets.
# NEVER put real values in this .example file (it IS committed).

# ── Cloud Postgres (read-only role recommended for the dashboard) ─────
# Supabase: Project → Settings → Database → Connection string (URI).
# Neon:     Dashboard → Connection Details → connection string.
DATABASE_URL = "postgresql://READONLY_USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# ── Internal-team authentication (Streamlit-native gate, see auth.py) ──
# Add one line per team member: username = "password".
# Secrets are encrypted on Streamlit Cloud and never live in the repo.
[auth]
cookie_key = "CHANGE_ME_random_long_string"   # reserved for future use

[auth.users]
hadi = "REPLACE_WITH_A_STRONG_PASSWORD"
# sara = "another-strong-password"
